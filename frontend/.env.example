# Copy to .env.local. Fixture mode is the zero-configuration default.
VITE_DATA_SOURCE=fixture
VITE_INVESTOR_AUTH_MODE=proxy

# HTTP mode keeps browser requests same-origin and sends /api through Vite's local proxy.
VITE_API_BASE_URL=/api/v1
FOUNDERLOOKUP_API_PROXY_TARGET=http://127.0.0.1:8000

# Required only for HTTP dev mode. Copy the exact value from backend/.env.
# This deliberately has no VITE_ prefix, so Vite never embeds it in browser assets.
FOUNDERLOOKUP_INVESTOR_API_KEY=replace-with-the-same-local-secret-as-the-backend
