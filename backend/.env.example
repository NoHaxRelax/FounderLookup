# Safe local defaults. Copy this file to .env and replace placeholders locally.
FOUNDERLOOKUP_ENV=development
FOUNDERLOOKUP_LOG_LEVEL=INFO
FOUNDERLOOKUP_DATA_DIR=.data
FOUNDERLOOKUP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Never commit the real investor credential.
FOUNDERLOOKUP_INVESTOR_API_KEY=replace-with-a-local-secret
# Use a separate high-entropy value to hash founder-status capabilities.
FOUNDERLOOKUP_FOUNDER_STATUS_PEPPER=replace-with-another-local-secret

# Bounded public-route and upload policy.
FOUNDERLOOKUP_INTAKE_RATE_LIMIT=10
FOUNDERLOOKUP_STATUS_RATE_LIMIT=60
FOUNDERLOOKUP_RATE_LIMIT_WINDOW_SECONDS=60
FOUNDERLOOKUP_MAXIMUM_DECK_BYTES=10485760
FOUNDERLOOKUP_MAXIMUM_COLLECTION_RESULTS=100
FOUNDERLOOKUP_MAXIMUM_RETRY_ATTEMPTS=3
# Opt in only when you want fictional, process-local data for evaluating the UI.
FOUNDERLOOKUP_DEMO_SEED_ENABLED=false
# Demo-only: required with the flag above when FOUNDERLOOKUP_ENV=production.
FOUNDERLOOKUP_DEMO_SEED_PRODUCTION_ACKNOWLEDGED=false

# Mistral OCR is approved only for deck extraction. A key alone never enables a request.
MISTRAL_API_KEY=replace-with-a-local-mistral-key
FOUNDERLOOKUP_MISTRAL_OCR_ENABLED=false
FOUNDERLOOKUP_MISTRAL_OCR_MODEL=mistral-ocr-latest
FOUNDERLOOKUP_MISTRAL_OCR_MAX_INPUT_BYTES=20000000
FOUNDERLOOKUP_MISTRAL_OCR_MAX_RESPONSE_BYTES=20000000
# Per-request page cap also bounds OCR provider cost; only pages 0 through cap-1 are requested.
FOUNDERLOOKUP_MISTRAL_OCR_MAX_PAGES=50
FOUNDERLOOKUP_MISTRAL_OCR_TIMEOUT_SECONDS=60
# This simple allowlist accepts only public; non-public data uses the controls below.
FOUNDERLOOKUP_MISTRAL_OCR_APPROVED_NON_PRIVATE_CLASSIFICATIONS=public

# Founder-private and investor-internal transfer stay blocked until every control is confirmed.
# Restricted data is never sent to external OCR.
FOUNDERLOOKUP_MISTRAL_OCR_ALLOW_PRIVATE=false
FOUNDERLOOKUP_MISTRAL_OCR_TRAINING_OPT_OUT_CONFIRMED=false
FOUNDERLOOKUP_MISTRAL_OCR_RETENTION_POSTURE=unconfirmed
FOUNDERLOOKUP_MISTRAL_OCR_REGION=
FOUNDERLOOKUP_MISTRAL_OCR_REGION_CONFIRMED=false
FOUNDERLOOKUP_MISTRAL_OCR_PURPOSE=
FOUNDERLOOKUP_MISTRAL_OCR_PURPOSE_CONFIRMED=false
# Demo-only alternative to asserting unknown provider/account controls as confirmed.
FOUNDERLOOKUP_MISTRAL_OCR_HACKATHON_PRIVATE_RISK_ACCEPTED=false

# Tavily is the human-selected P0 generic public-web provider. A key alone never enables it.
TAVILY_API_KEY=replace-with-a-local-tavily-key
FOUNDERLOOKUP_TAVILY_ENABLED=false
# Search uses basic depth and one bounded query by default. Tavily currently caps results at 20.
FOUNDERLOOKUP_TAVILY_MAX_QUERIES=1
FOUNDERLOOKUP_TAVILY_MAX_RESULTS=10
# At most this many returned original URLs are passed to Extract.
FOUNDERLOOKUP_TAVILY_MAX_PAGES=5
FOUNDERLOOKUP_TAVILY_MAX_CONTENT_BYTES=500000
FOUNDERLOOKUP_TAVILY_MAX_RESPONSE_BYTES=2000000
FOUNDERLOOKUP_TAVILY_TIMEOUT_SECONDS=20
# Advanced search costs two Tavily credits but materially improves precise founder discovery.
FOUNDERLOOKUP_TAVILY_SEARCH_DEPTH=advanced
# Advanced extraction improves embedded public deck/page retrieval (two credits per five URLs).
FOUNDERLOOKUP_TAVILY_EXTRACT_DEPTH=advanced
# Empty means any otherwise-safe public HTTP(S) domain. Use bare comma-separated hostnames.
FOUNDERLOOKUP_TAVILY_ALLOWED_DOMAINS=
# Authentication-heavy social sources remain denied unless a later policy explicitly replaces this.
FOUNDERLOOKUP_TAVILY_EXCLUDED_DOMAINS=linkedin.com,facebook.com,instagram.com,x.com,twitter.com

# Provider-neutral ceilings apply across the entire enabled adapter fan-out. The cache TTL makes
# repeated on-demand or external-cron triggers idempotent without enabling an internal scheduler.
FOUNDERLOOKUP_SOURCING_MAX_RESULTS=10
FOUNDERLOOKUP_SOURCING_MAX_PAGES=5
FOUNDERLOOKUP_SOURCING_MAX_CONTENT_BYTES=500000
FOUNDERLOOKUP_SOURCING_TIMEOUT_SECONDS=20
FOUNDERLOOKUP_SOURCING_CACHE_TTL_SECONDS=900
FOUNDERLOOKUP_SOURCING_MAX_FOLLOW_UP_ROUNDS=1
FOUNDERLOOKUP_SOURCING_MAX_DISCOVERY_CALLS=12

# Direct linked pitch-deck download is disabled until this separate HTTPS host allowlist is set.
# A base domain also permits its subdomains, so googleusercontent.com covers signed download hosts.
FOUNDERLOOKUP_PUBLIC_PDF_ALLOWED_DOMAINS=
FOUNDERLOOKUP_PUBLIC_PDF_EXCLUDED_DOMAINS=
FOUNDERLOOKUP_PUBLIC_PDF_MAX_BYTES=5000000
FOUNDERLOOKUP_PUBLIC_PDF_TIMEOUT_SECONDS=30
FOUNDERLOOKUP_PUBLIC_PDF_MAX_REDIRECTS=5

# GPT-5.6 Luna strict Structured Outputs after bounded public acquisition.
# A key alone never enables a call. Private use requires both explicit flags below.
OPENAI_API_KEY=replace-with-a-local-openai-key
FOUNDERLOOKUP_OPENAI_STRUCTURED_ENABLED=false
FOUNDERLOOKUP_OPENAI_MODEL=gpt-5.6-luna
FOUNDERLOOKUP_OPENAI_MAX_INPUT_BYTES=200000
FOUNDERLOOKUP_OPENAI_MAX_OUTPUT_TOKENS=2000
FOUNDERLOOKUP_OPENAI_MAX_RESPONSE_BYTES=1000000
FOUNDERLOOKUP_OPENAI_TIMEOUT_SECONDS=30
FOUNDERLOOKUP_OPENAI_ALLOW_PRIVATE=false
FOUNDERLOOKUP_OPENAI_HACKATHON_PRIVATE_RISK_ACCEPTED=false

# Authoritative public-source adapters are independently opt-in and disabled by default.
# GitHub's token is optional and server-only; leave it empty for unauthenticated public API use.
GITHUB_TOKEN=
FOUNDERLOOKUP_GITHUB_ENABLED=false
FOUNDERLOOKUP_HACKERNEWS_ENABLED=false
FOUNDERLOOKUP_OPENALEX_ENABLED=false
FOUNDERLOOKUP_SEMANTIC_SCHOLAR_ENABLED=false
FOUNDERLOOKUP_PATENTSVIEW_ENABLED=false
